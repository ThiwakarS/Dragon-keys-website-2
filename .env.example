# =============================================
# Dragon Keys — Environment Variables Template
# =============================================
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — NEVER commit real keys.
#
# All Vite env vars MUST start with VITE_ to be exposed to the browser.
# =============================================

# Clerk (get from https://dashboard.clerk.com)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXX

# Supabase (get from https://supabase.com/dashboard → your project → Settings → API)
VITE_SUPABASE_URL=https://XXXXXXXXXX.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiXXXXXXXXXXXXXXXXXXXXXXXXXX

# Your public contact info (safe to expose)
VITE_WHATSAPP_NUMBER=919876543210
VITE_SUPPORT_EMAIL=support@dragonkeys.dev
